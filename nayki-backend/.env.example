# App Config
APP_ENV=local
API_PORT=8000
LOG_LEVEL=info

# Database Config
# For PostgreSQL with PostGIS
DATABASE_URL=postgresql+asyncpg://nayki_user:nayki_password@localhost:5432/nayki_db
# Sync URL is useful for Alembic migrations
SYNC_DATABASE_URL=postgresql+psycopg://nayki_user:nayki_password@localhost:5432/nayki_db

# Redis Config
REDIS_URL=redis://localhost:6379/0

# Security Config
# In local development, set DEV_AUTH_ENABLED=true to bypass Firebase Auth validation.
# Never set DEV_AUTH_ENABLED=true in production or staging (APP_ENV != local).
DEV_AUTH_ENABLED=true
JWT_ISSUER=https://securetoken.google.com/nayki-production
FIREBASE_PROJECT_ID=nayki-production
FIREBASE_CREDENTIALS_JSON={"type": "service_account", "project_id": "nayki-production"}

# Safety Config
H3_RESOLUTION=9

# Optional Integrations
GRAPHHOPPER_BASE_URL=http://localhost:8989
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_ROUTES_API_KEY=your_google_routes_api_key_here
FCM_SERVER_KEY=your_firebase_fcm_server_key_here
